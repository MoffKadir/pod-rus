widget = {
	name = "POD_event_window_widget_demonic_pact"
	parentanchor = right|top
	position = { -102 86 }
	size = { 480 424 }
	
	background = {
		using = Background_Area_Dark
	}

	vbox = {
		layoutpolicy_horizontal = expanding

		state = {
			name = init
			trigger_on_create = yes
			on_start = "[GetVariableSystem.Set('demonic_pact_creator_tab', 'obligation')]"
		}

		hbox = {
			button_tab = {
				size = { 0 38 }
				layoutpolicy_horizontal = expanding
				onclick = "[GetVariableSystem.Set('demonic_pact_creator_tab', 'obligation')]"
				down = "[GetVariableSystem.HasValue( 'demonic_pact_creator_tab', 'obligation' )]"

				text_single = {
					text = "game_concept_demonic_pact_obligation"
					parentanchor = center
				}
			}
			button_tab = {
				size = { 0 38 }
				layoutpolicy_horizontal = expanding
				onclick = "[GetVariableSystem.Set('demonic_pact_creator_tab', 'frequency')]"
				down = "[GetVariableSystem.HasValue( 'demonic_pact_creator_tab', 'frequency' )]"

				text_single = {
					text = "game_concept_demonic_pact_frequency"
					parentanchor = center
				}
			}
			button_tab = {
				size = { 0 38 }
				layoutpolicy_horizontal = expanding
				onclick = "[GetVariableSystem.Set('demonic_pact_creator_tab', 'consequence')]"
				down = "[GetVariableSystem.HasValue( 'demonic_pact_creator_tab', 'consequence' )]"

				text_single = {
					text = "game_concept_demonic_pact_the_fine_print"
					parentanchor = center
				}
			}
		}
		
		scrollbox = {
			layoutpolicy_vertical = expanding
			layoutpolicy_horizontal = expanding
			
			blockoverride "scrollbox_background" {}
			blockoverride "scrollbox_background_fade" {}

			blockoverride "scrollbox_content" {
				background = {
					using = Background_Area_Dark
				}
				vbox = {
					datamodel = "[GetPlayer.MakeScope.GetList('pact_stipulation_list')]"
					layoutpolicy_horizontal = expanding
					spacing = 4

					item = {
						button_standard_hover = {
							visible = "[EqualTo_string( GetVariableSystem.Get('demonic_pact_creator_tab'), Scope.GetVariable('type').GetFlagKey )]"
							
							size = { 0 35 }
							layoutpolicy_horizontal = expanding
							
							onclick = "[GetScriptedGui('demonic_pact_creator_select_detail_script').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('selected_stipulation', Scope.Story.MakeScope).End)]"
							enabled = "[GetScriptedGui('demonic_pact_creator_select_detail_script').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('selected_stipulation', Scope.Story.MakeScope).End)]"
							
							hbox = {
								margin = { 5 0 }

								button_radio = {
									size = { 30 30 }
									frame = "[BoolTo1And2( GetScriptedGui('demonic_pact_creator_select_detail_script').IsShown(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('selected_stipulation', Scope.Story.MakeScope).End) )]"
									alwaystransparent = yes
								}
								
								spacer = { size = { 12 0 } }

								text_single = {
									alwaystransparent = yes
									text = "[Localize(Concatenate('POD_stipulation_', Scope.GetVariable('id').GetFlagKey))]"
									align = nobaseline
									max_width = 345
								}

								tooltip = "[GetScriptedGui('demonic_pact_creator_select_detail_script').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('selected_stipulation', Scope.Story.MakeScope).End)]"
								using = tooltip_ws

								expand = {}

								text_single = {
									alwaystransparent = yes
									text = "POD_stipulation_value"
									align = nobaseline
									min_width = 56
									max_width = 56
								}
							}
						}
					}
				}
			}
		}
	}
}
vbox = {
	name = "POD_event_window_widget_demonic_pact_preview"
	layoutpolicy_horizontal = expanding
	
	widget = {
		size = { 450 220 }
		
		background = {
			texture = "gfx/interface/window_contract/tile_contract_2_shadow.dds"
			spriteType = Corneredtiled
			spriteborder = { 200 200 }
		}
		
		background = {
			texture = "gfx/interface/window_contract/tile_contract_2_flat.dds"
			spriteType = Corneredtiled
			spriteborder = { 200 200 }
			
			modify_texture = {
				texture = "gfx/interface/window_contract/tile_contract_2_texture.dds"
				spriteType = Corneredstretched
				blend_mode = overlay
			}
			
			modify_texture = {
				color = { 0.65 0.4 0.3 1.0 }
				blend_mode = multiply
				alpha = 0.2
			}

			modify_texture = {
				texture = "gfx/interface/component_overlay/overlay_effect.dds"
				blend_mode = overlay
			}
		}
		
		background = {
			fittype = centercrop
			framesize = { 1144 486 }
			texture = "gfx/interface/window_legend_chronicle/marginalia_illustration.dds"
			color = { 0.5 0.0 0.0 1.0 }

			modify_texture = {
				texture = "gfx/interface/component_masks/mask_fade_vertical_up.dds"
				blend_mode = alphamultiply
				alpha = 0.8
			}

			modify_texture = {
				texture = "gfx/interface/component_masks/mask_clouds.dds"
				blend_mode = alphamultiply
				alpha = 0.9
			}
			
			modify_texture = {
				texture = "gfx/interface/component_masks/mask_scratches.dds"
				blend_mode = alphamultiply
				spriteType = corneredTiled
				alpha = 0.8
			}

			modify_texture = {
				texture = "gfx/interface/component_masks/mask_fade_horizontal_right.dds"
				blend_mode = alphamultiply
				mirror = horizontal
				alpha = 0.9
			}
		}
		
		vbox = {
			margin = { 20 12 }
			
			text_single = {
				text = "POD_infernalism_events.1.pact"
				default_format = "#color:{0.5,0,0,1};glow_color:{0.3,0,0,0.75}"
				fontsize = 24
				using = Font_Type_Flavor
				layoutpolicy_horizontal = expanding
				align = center
			}
			
			spacer = { size = { 0 12 } }
			
			text_multi = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				text = "[GetScriptedGui('demonic_pact_creator_preview_script').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('demon', EventWindowWidget.GetScope.sC('recipient').MakeScope).End)]"
				default_format = "#light_background"
				using = Text_Light_Background_Overrides
			}
			
			spacer = { size = { 0 6 } }
		}
	}
	
	spacer = { size = { 0 16 } }

	vbox = {
		layoutpolicy_horizontal = expanding
		margin_bottom = 1
		
		datamodel = "[EventWindow.AccessEventWindowData.GetOptions]"
		
		item = {
			pod_fake_event_button = {
				layoutpolicy_horizontal = expanding
				
				enabled = "[GetScriptedGui('demonic_pact_creator_finish_script').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('demon', EventWindowWidget.GetScope.sC('recipient').MakeScope).End)]"
				
				onclick = "[GetScriptedGui('demonic_pact_creator_finish_script').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('demon', EventWindowWidget.GetScope.sC('recipient').MakeScope).End)]"
				onclick = "[EventOption.Select]"
				block "pause_onclick" {}
				
				blockoverride "button_text" {
					text = "POD_infernalism_events.1.confirm"
				}
				blockoverride "button_tooltip" {
					tooltip = "[GetScriptedGui('demonic_pact_creator_finish_script').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('demon', EventWindowWidget.GetScope.sC('recipient').MakeScope).End)]"
				}
			}
		}
	}
}
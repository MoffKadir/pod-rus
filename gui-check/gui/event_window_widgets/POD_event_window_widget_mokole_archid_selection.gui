
scrollbox = {
	name = "POD_event_window_widget_mokole_archid_selection"
	
	position = { -100 72 }
	size = { 390 460 }
	parentanchor = right|top

	blockoverride "scrollbox_margins" {}
	blockoverride "scrollbox_background" {}
	blockoverride "scrollbox_background_fade" {}
	blockoverride "scrollbox_content"
	{
		vbox = {
			layoutpolicy_horizontal = expanding
	
			
			margin = { 16 16 }
	
			spacing = 12
	
			background = {
				using = Background_Area_ExtraDark
			}
			
			fixedgridbox = {
				layoutpolicy_horizontal = expanding
				datamodel = "[GetPlayer.MakeScope.GetList('ArchidOptionsList')]"
				datamodel_wrap = 2
				addcolumn = 180
				addrow = 30
				setitemsizefromcell = yes
				flipdirection = yes

				item = {
					button_event_standard = {
						layoutpolicy_horizontal = expanding
						text = "[Localize(Concatenate(Scope.GetFlagKey,'_button_loc'))]"
						tooltipwidget = {
							static_modifier_tooltip = {
								datacontext = "[GetModifier(Concatenate(Scope.GetFlagKey,'_modifier'))]"
							}
						}

						onclick = "[GetScriptedGui('POD_archid_current_choice_toggle_button').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('flag', MakeScopeFlag(Scope.GetFlagKey)).End)]"
						enabled = "[Not(GetScriptedGui('POD_archid_previous_choice_button').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('flag', MakeScopeFlag(Scope.GetFlagKey)).End))]"
						down = "[GetScriptedGui('POD_archid_current_choice_button').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('flag', MakeScopeFlag(Scope.GetFlagKey)).End)]"
					}
				}

				#Shows remaining picks
				widget = {
					allow_outside = yes
					hbox = {
						position = { 70 380 }
						spacing = 8
						background = {
							using = Text_Label_Background
							margin = { 18 -3 }
							margin_bottom = 6
						}
						text_single = {
							text = "POD_ARCHID_REMAINING_OPTIONS"
							fontsize = 20
						}
						text_single = {
							text = "[GetPlayer.MakeScope.ScriptValue('mokole_available_archid_GUI_options')]"
							fontsize = 20
						}
						
					}
				}
			}
		}
	}
}
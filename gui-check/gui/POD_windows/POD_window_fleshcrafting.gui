@show_fleshcraft_window = "[GetPlayer.MakeScope.Var('fleshcraft_target').IsSet]"

widget = {
	name = "pod_fleshcrafting_window"
	visible = "[And( And( Not( IsPauseMenuShown ), IsDefaultGUIMode ), GetPlayer.IsValid)]"
	layer = middle
	size = { 100% 100% }

	window = {
		visible = @show_fleshcraft_window
		
		parentanchor = center
		position = { 0 -1000 }
		alpha = 0

		state = {
			name = _hide
			using = Animation_Curve_Default
			duration = 0.6

			bezier = { 0 1 0 1 }

			position = { 0 -1000 }
			alpha = 0
		}

		state = {
			name = _show
			duration = 0.8

			start_sound = {
				soundeffect = "event:/DLC/FP2/SFX/UI/fp2_struggle_ui_intro_end_animate"
			}

			bezier = { 0 1 0 1 }

			position = { 0 0 }
			alpha = 1
		}
		
		state = {
			name = show_after_loading_save
			
			# fix for window getting stuck off-screen after loading a save
			trigger_when = @show_fleshcraft_window
			
			position = { 0 -1000 }
			alpha = 0
			
			next = _show
		}

		using = Window_Decoration

		background = {
			texture = "gfx/interface/component_tiles/tile_window_background.dds"
			spriteType = Corneredtiled
			spriteborder = { 18 0 }
			texture_density = 2
			margin = { -23 -17 }
	
			modify_texture = {
				texture = "gfx/interface/component_overlay/overlay_effect.dds"
				blend_mode = overlay
			}
		}

		background = {
			texture = "gfx/interface/component_tiles/tile_window_background.dds"
			spriteType = Corneredtiled
			spriteborder = { 18 0 }
			texture_density = 2
			margin = { -23 -17 }
			
		# 	shaderfile = "gfx/FX/POD_shaders/POD_shaders_with_inputs.shader"
		# 	effectname = "PODVeinsBNW"
			
			shaderfile = "gfx/FX/POD_shaders/POD_shaders_with_inputs.shader"
			effectname = "PODGiger"
	
			# modify_texture = {
			# 	texture = "gfx/interface/transparent_pixel.dds"
			# 	blend_mode = alphamultiply
			# 	alpha = 0.6
			# }
					
			modify_texture = {
				texture = "gfx/interface/component_masks/mask_fade_corner.dds"
				blend_mode = alphamultiply
				alpha = 0.5
			}
					
			modify_texture = {
				texture = "gfx/interface/component_masks/mask_scratches.dds"
				blend_mode = alphamultiply
				spriteType = corneredTiled
				alpha = 0.75
				texture_density = 4
			}
			
			modify_texture = {
				texture = "gfx/interface/component_masks/mask_clouds.dds"
				blend_mode = alphamultiply
				spriteType = corneredTiled
				alpha = 0.4
			}
		}
		
		# j a n k
		state = {
			name = _pause
			trigger_when = "[Not(IsGamePaused)]"
			on_start = "[OnPause]"
		}
		
		hbox = {
			margin_left = 40
			margin_right = 40
			margin_top = 24
			margin_bottom = 20

			set_parent_size_to_minimum = yes
		
			# done via animation state so that sounds can overlap each other
			# instead of having to wait for the previous one to end
			state = {
				name = fleshcraft_perk_clicksound
				end_sound = {
					soundeffect = "event:/SFX/UI/Unique/CharacterLifestyle/sfx_ui_unique_lifestyle_intrigue"
					# alternatives
					#soundeffect = "event:/SFX/UI/Unique/CharacterLifestyle/sfx_ui_unique_lifestyle_learning"
					#soundeffect = "event:/DLC/EP1/SFX/UI/artifact_reforge"
				}
			}

			##### Left side: Character display
			widget = {
				layoutpolicy_horizontal = expanding
				#size = { 960 800 }
				size = { 1040 800 }
				
				background = {
					texture = "gfx/interface/window_contract/tile_contract_2_flat.dds"
					spriteType = Corneredtiled
					spriteborder = { 200 200 }
					
					modify_texture = {
						name = "paper_texture_overlay"
						texture = "gfx/interface/window_contract/tile_contract_2_texture.dds"
						spriteType = Corneredstretched
						blend_mode = overlay
					}
					
					modify_texture = {
						color = { 0.2 0.3 0.6 1.0 }
						blend_mode = multiply
						alpha = 0.4
					}

					modify_texture = {
						texture = "gfx/interface/component_overlay/overlay_effect.dds"
						blend_mode = overlay
					}

					modify_texture = {
						texture = "gfx/interface/component_overlay/overlay_effect.dds"
						blend_mode = overlay
						alpha = 0.5
					}
				}
				
				background = {
					using = pod_fleshcraft_physician_bg
					
					alpha = 0.95
					
					modify_texture = {
						texture = "gfx/interface/component_masks/mask_fade_vertical_up.dds"
						blend_mode = alphamultiply
						mirror = vertical
						alpha = "[Max_float( '(float)0.5', Subtract_float( '(float)1.5', Divide_float( FixedPointToFloat(GetPlayer.MakeScope.ScriptValue('POD_fleshcrafting_current_complexity')), '(float)50.0' ) ) )]"
					}
					
					# modify_texture = {
					# 	texture = "gfx/interface/component_masks/mask_fade_corner.dds"
					# 	blend_mode = alphamultiply
					# 	mirror = horizontal|vertical
					# 	alpha = 0.2
					# }
				}
				
				background = {
					using = pod_fleshcraft_physician_bg
					
					shaderfile = "gfx/FX/POD_shaders/POD_shaders_with_inputs.shader"
					effectname = "PODVeinsAlpha"
				}
				
				pod_fleshcraft_portrait = {
					# skeleton texture is less wide since it doesn't have a wide silhouette
					# unlike the main portrait, which might have wings and the like
					size = { 400 750 }
					datacontext = "[GetPlayer.MakeScope.Var('fleshcraft_skeleton').Char]"
					alpha = 1.0
					grayscale = no
					visible = "[PlayerGuiIsShown(GetPlayer.Custom('PODFleshcraftSkeletonIsShown'))]"
				}
				pod_fleshcraft_portrait = {
					datacontext = "[GetPlayer.MakeScope.Var('fleshcraft_target').Char]"
					alpha = 0.75
					grayscale = yes
				}
				
				text_single = {
					text = "POD_fleshcrafting_title"
					parentanchor = top|hcenter
					position = { 1 16 }
					fontsize = 32
					default_format = "#color:{0.2,0.0,0.0,1.0};glow_color:{0.2,0.0,0.0,1.0};FONT:PODSubtitles"
					max_width = 940
				}
				text_single = {
					text = "POD_fleshcrafting_title"
					parentanchor = top|hcenter
					position = { 0 14 }
					fontsize = 32
					default_format = "#color:{0.91,0.9,0.88,0.85};FONT:PODSubtitles"
					max_width = 940
				}
				
				pod_fleshcraft_perk_popup = {
					position = { 70 80 }
					blockoverride "text_title" { text = "fc_head" }
					blockoverride "button_flesh" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_head_flesh')]"
						onclick = "[SelectFleshcraftLayer('fc_head_flesh')]"
						onrightclick = "[ClearFleshcraftLayer('fc_head_flesh')]"
					}
					blockoverride "button_bone" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_head_bone')]"
						onclick = "[SelectFleshcraftLayer('fc_head_bone')]"
						onrightclick = "[ClearFleshcraftLayer('fc_head_bone')]"
					}
					blockoverride "flesh_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_head_flesh')]"
					}
					blockoverride "bone_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_head_bone')]"
					}
				}
				
				pod_fleshcraft_perk_popup = {
					parentanchor = top|right
					position = { -70 80 }
					blockoverride "text_title" { text = "fc_torso" }
					blockoverride "button_flesh" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_torso_flesh')]"
						onclick = "[SelectFleshcraftLayer('fc_torso_flesh')]"
						onrightclick = "[ClearFleshcraftLayer('fc_torso_flesh')]"
					}
					blockoverride "button_bone" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_torso_bone')]"
						onclick = "[SelectFleshcraftLayer('fc_torso_bone')]"
						onrightclick = "[ClearFleshcraftLayer('fc_torso_bone')]"
					}
					blockoverride "flesh_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_torso_flesh')]"
					}
					blockoverride "bone_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_torso_bone')]"
					}
				}
				
				pod_fleshcraft_perk_popup = {
					position = { 10 320 }
					blockoverride "text_title" { text = "fc_arm_r" }
					blockoverride "button_flesh" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_arm_r_flesh')]"
						onclick = "[SelectFleshcraftLayer('fc_arm_r_flesh')]"
						onrightclick = "[ClearFleshcraftLayer('fc_arm_r_flesh')]"
					}
					blockoverride "button_bone" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_arm_r_bone')]"
						onclick = "[SelectFleshcraftLayer('fc_arm_r_bone')]"
						onrightclick = "[ClearFleshcraftLayer('fc_arm_r_bone')]"
					}
					blockoverride "flesh_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_arm_r_flesh')]"
					}
					blockoverride "bone_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_arm_r_bone')]"
					}
				}
				
				pod_fleshcraft_perk_popup = {
					parentanchor = top|right
					position = { -10 320 }
					blockoverride "text_title" { text = "fc_arm_l" }
					blockoverride "button_flesh" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_arm_l_flesh')]"
						onclick = "[SelectFleshcraftLayer('fc_arm_l_flesh')]"
						onrightclick = "[ClearFleshcraftLayer('fc_arm_l_flesh')]"
					}
					blockoverride "button_bone" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_arm_l_bone')]"
						onclick = "[SelectFleshcraftLayer('fc_arm_l_bone')]"
						onrightclick = "[ClearFleshcraftLayer('fc_arm_l_bone')]"
					}
					blockoverride "flesh_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_arm_l_flesh')]"
					}
					blockoverride "bone_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_arm_l_bone')]"
					}
				}
				
				pod_fleshcraft_perk_popup = {
					position = { 70 560 }
					blockoverride "text_title" { text = "fc_leg_r" }
					blockoverride "button_flesh" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_leg_r_flesh')]"
						onclick = "[SelectFleshcraftLayer('fc_leg_r_flesh')]"
						onrightclick = "[ClearFleshcraftLayer('fc_leg_r_flesh')]"
					}
					blockoverride "button_bone" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_leg_r_bone')]"
						onclick = "[SelectFleshcraftLayer('fc_leg_r_bone')]"
						onrightclick = "[ClearFleshcraftLayer('fc_leg_r_bone')]"
					}
					blockoverride "flesh_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_leg_r_flesh')]"
					}
					blockoverride "bone_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_leg_r_bone')]"
					}
				}
				
				pod_fleshcraft_perk_popup = {
					parentanchor = top|right
					position = { -70 560 }
					blockoverride "text_title" { text = "fc_leg_l" }
					blockoverride "button_flesh" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_leg_l_flesh')]"
						onclick = "[SelectFleshcraftLayer('fc_leg_l_flesh')]"
						onrightclick = "[ClearFleshcraftLayer('fc_leg_l_flesh')]"
					}
					blockoverride "button_bone" {
						datacontext = "[GetPlayer.MakeScope.Var('fc_leg_l_bone')]"
						onclick = "[SelectFleshcraftLayer('fc_leg_l_bone')]"
						onrightclick = "[ClearFleshcraftLayer('fc_leg_l_bone')]"
					}
					blockoverride "flesh_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_leg_l_flesh')]"
					}
					blockoverride "bone_glow_visible" {
						visible = "[IsFleshcraftLayerSelected('fc_leg_l_bone')]"
					}
				}
			}

			#### Right side: Details
			widget = {
				size = { 400 0 }
				layoutpolicy_vertical = expanding
				
				# Selecting a perk
				vbox = {
					visible = "[GetPlayer.MakeScope.Var('fc_selected_layer').IsSet]"
					layoutpolicy_vertical = expanding
					layoutpolicy_horizontal = expanding
					margin = { 0 12 }
					
					text_single = {
						text = "POD_fleshcrafting_selected_layer"
						default_format = "#glow_color:{0.25,0.0,0.0,1.0};FONT:TitleFont"
						fontsize = 24
					}
					
					text_single = {
						text = "POD_fleshcrafting_layer_confirm"
					}
					
					spacer = { size = { 0 18 } }
					
					# TODO FLESHCRAFT: make scrollbox
					vbox = {
						layoutpolicy_horizontal = expanding
						datamodel = "[GetPlayer.MakeScope.GetList('fc_layer_perks')]"
						margin = { 6 0 }
					
						# TODO FLESHCRAFT: force reload somehow
						
						item = {
							button_standard_hover = {
								onclick = "[GetScriptedGui('POD_fleshcrafting_select_perk').Execute( GuiScope.SetRoot(GetPlayer.MakeScope).AddScope( 'flag', MakeScopeFlag(Scope.GetFlagKey) ).End )]"
								onclick = "[PdxGuiInterruptThenTriggerAllAnimations('fleshcraft_perk_clicksound','fleshcraft_perk_clicksound')]"
								
								visible = "[GetScriptedGui('POD_fleshcrafting_select_perk').IsShown( GuiScope.SetRoot(GetPlayer.MakeScope).AddScope( 'flag', MakeScopeFlag(Scope.GetFlagKey) ).End )]"
								enabled = "[GetScriptedGui('POD_fleshcrafting_select_perk').IsValid( GuiScope.SetRoot(GetPlayer.MakeScope).AddScope( 'flag', MakeScopeFlag(Scope.GetFlagKey) ).End )]"
								
								layoutpolicy_horizontal = expanding
								
								vbox = {
									margin = { 0 16 }
									margin_top = 8
									
									resizeparent = yes
							 		datacontext = "[GetPerk(Scope.GetFlagKey)]"
									
									background = {
										using = pod_fleshcraft_perk_bg_solid
										texture_density = 2
										color = { 0 0 0 0.6 }
										
										modify_texture = {
											texture = "gfx/interface/icons/map_coa/at_war_mask.dds"
											blend_mode = alphamultiply
											spriteType = corneredTiled
										}
									}
									background = {
										using = pod_fleshcraft_perk_bg_frames
										texture_density = 1.5
									}
									
									hbox = {
										text_single = {
											text = "POD_fleshcrafting_perk_name"
											default_format = "#glow_color:{0.25,0.0,0.0,1.0};FONT:PODSubtitles;bold"
											max_width = 360
											
											fontsize = 20
										}
									}
									
									spacer = { size = { 0 2 } }
									
									text_multi = {
										text = "[Perk.GetEffectDescription( GetPlayer.MakeScope.Var('fleshcraft_target').Char.Self )]"
										default_format = "#glow_color:{0.0,0.0,0.0,0.5}"
										alwaystransparent = yes
										align = center
										autoresize = yes
										#resizeparent = yes
										max_width = 360
									}
								}
							}
						}
					}
					
					expand = {}
				}
				
				# Default view: Success chance, Effect preview, Confirm button
				vbox = {
					visible = "[Not(GetPlayer.MakeScope.Var('fc_selected_layer').IsSet)]"
					layoutpolicy_vertical = expanding
					layoutpolicy_horizontal = expanding
					margin = { 0 12 }
					
					text_single = {
						text = "POD_fleshcrafting_total_complexity"
						default_format = "#glow_color:{0.25,0.0,0.0,1.0};FONT:TitleFont"
						fontsize = 24
					}
						
					spacer = { size = { 0 6 } }
					
					text_single = {
						text = "POD_fleshcrafting_success_chance_tt"
						default_format = "#glow_color:{0.25,0.0,0.0,1.0};FONT:TitleFont"
						fontsize = 24
					}
					
					spacer = { size = { 0 36 } }
					
					text_multi = {
						text = "[PlayerGuiBuildTooltip('POD_fleshcrafting_preview')]"
						default_format = "#glow_color:{0.0,0.0,0.0,0.5}"
						autoresize = yes
						max_width = 330
						
						background = {
							margin = { 24 24 }
							margin_top = 18
							
							using = pod_fleshcraft_perk_bg_solid
							
							texture_density = 2
							color = { 0 0 0 0.6 }
							
							modify_texture = {
								texture = "gfx/interface/icons/map_coa/at_war_mask.dds"
								blend_mode = alphamultiply
								spriteType = corneredTiled
							}
						}
						
						background = {
							using = pod_fleshcraft_perk_bg_frames
							texture_density = 1.5
							margin = { 18 18 }
							
							margin_top = 12
						}
					}
					
					expand = {}
					
					hbox = {
						background = {
							margin = { 16 12 }
							margin_top = 10
							
							using = pod_fleshcraft_perk_bg_solid
							
							texture_density = 2
							color = { 0 0 0 0.6 }
							
							modify_texture = {
								texture = "gfx/interface/icons/map_coa/at_war_mask.dds"
								blend_mode = alphamultiply
								spriteType = corneredTiled
							}
						}
						background = {
							using = pod_fleshcraft_perk_bg_frames
							texture_density = 1.5
							margin = { 10 6 }
							alpha = 0.5
							
							margin_top = 4
						}
						
						button_clear = {
							size = { 40 40 }
							alpha = 0.9
							onclick = "[PlayerGuiExecute('POD_fleshcrafting_clear')]"
							tooltip = "POD_fleshcrafting_button_clear"
							using = POD_flat_icon_shadow
							using = tooltip_ws
						}
						
						spacer = { size = { 12 0 } }
						
						button_replace = {
							size = { 40 40 }
							alpha = 0.9
							onclick = "[PlayerGuiExecute('POD_fleshcrafting_reset')]"
							tooltip = "POD_fleshcrafting_button_reset"
							using = POD_flat_icon_shadow
							using = tooltip_ws
						}
					}
					
					spacer = { size = { 0 32 } }
					
					hbox = {
						layoutpolicy_horizontal = expanding
						
						expand = {}
						
						button_standard_clean = {
							default_format = "#V;glow_color:{0.0,0.0,0.0,1.0}"
							
							text = "POD_fleshcrafting_confirm"
							tooltip = "[PlayerGuiBuildTooltip('POD_fleshcrafting_button')]"
							enabled = "[PlayerGuiIsValid('POD_fleshcrafting_button')]"
							
							onclick = "[PlayerGuiExecute('POD_fleshcrafting_button')]"
							
							background = {
								texture = "gfx/interface/buttons/button_standard.dds"
								framesize = { 252 80 }
								frame = 4
								color = { 1.0 0.3 0.4 1.0 }
								
								using = pod_fleshcraft_generic_bg
							}
							
							background = {
								fittype = centercrop
								framesize = { 1144 486 }
								texture = "gfx/interface/window_legend_chronicle/marginalia_illustration_indian.dds"
								color = { 0.0 0.0 0.0 1.0 }
								
								using = pod_fleshcraft_generic_bg
							}
						}
						
						spacer = { size = { 8 0 } }
						
						button_tertiary = {
							text = "CANCEL_BUTTON"
							shortcut = "close_window"
							onclick = "[PlayerGuiExecute('POD_fleshcrafting_cancel')]"
						}
						
						expand = {}
					}
				}
			}
		}
	}
}

template pod_fleshcraft_physician_bg {
	texture = "gfx/interface/illustrations/event_scenes/study_physician.dds"
	fittype = centercrop
	framesize = { 1592 848 }
	
	modify_texture = {
		color = { 1.0 0.0 0.03 1.0 }
		alpha = "[Divide_float( FixedPointToFloat(GetPlayer.MakeScope.ScriptValue('POD_fleshcrafting_current_complexity')), '(float)50.0' )]"
		blend_mode = multiply
	}
	
	modify_texture = {
		texture = "gfx/interface/component_overlay/overlay_effect.dds"
		blend_mode = overlay
	}
	
	modify_texture = {
		texture = "gfx/interface/component_overlay/overlay_effect.dds"
		blend_mode = overlay
	}
	
	modify_texture = {
		texture = "gfx/interface/window_contract/tile_contract_2_flat.dds"
		spriteType = Corneredtiled
		spriteborder = { 200 200 }
		blend_mode = alphamultiply
	}
	
	modify_texture = {
		texture = "gfx/interface/component_masks/mask_scratches.dds"
		blend_mode = alphamultiply
		spriteType = corneredTiled
		alpha = 0.15
		texture_density = 4
	}
}

template pod_fleshcraft_generic_bg {
	modify_texture = {
		texture = "gfx/interface/component_masks/mask_scratches.dds"
		blend_mode = alphamultiply
		spriteType = corneredTiled
		alpha = 0.1
	}
	
	modify_texture = {
		texture = "gfx/interface/component_masks/mask_clouds.dds"
		blend_mode = alphamultiply
		spriteType = corneredTiled
		alpha = 0.3
	}
	
	modify_texture = {
		texture = "gfx/interface/component_masks/mask_fade_horizontal_middle_inverse.dds"
		blend_mode = alphamultiply
		alpha = 0.6
	}
}

template pod_fleshcraft_perk_bg_solid {
	texture = "gfx/interface/component_masks/mask_rough_edges.dds"
	spriteType = Corneredtiled
	spriteborder = { 20 20 }
	texture_density = 5
	
	using = pod_fleshcraft_generic_bg
}

template pod_fleshcraft_perk_bg_frames {
	using = Background_Frame
	texture_density = 2
	color = { 0.65 0.68 0.72 0.5 }
	margin = { -3 -3 }
}

template pod_fleshcraft_perk_text {
	margin = { 14 10 }
	margin_top = 4
	default_format = "#medium;glow_color:{0,0,0,1}"
	autoresize = yes
	resizeparent = yes
	max_width = 340
	#max_width = 280
	max_height = 130
	align = center
	alwaystransparent = yes
}

types PODFleshcraftTypes
{
	# based on the portrait from portrait_legend_chronicle
	type pod_fleshcraft_portrait = portrait_button {
		datacontext = "[GetPlayer.MakeScope.Var('fleshcraft_target').Char]"
		alpha = 1.0
		
		size = { 100% 750 }
		parentanchor = bottom|hcenter

		using = portrait_base
		alwaystransparent = yes
		tooltip_visible = no

		#portrait_texture = "[Character.GetPortrait( 'environment_painterly', 'shop_camera_main_near_angle_0', 'personality_zealous', PdxGetWidgetScreenSize( PdxGuiWidget.Self ) )]"
		# alternatively: Character.GetAnimatedPortrait()
		# pregnant pose on male characters as a neutral placeholder pose
		portrait_texture = "[Character.GetPortrait( 'POD_environment_hud', 'shop_camera_main_near_angle_0', Select_CString( Character.IsFemale, 'personality_zealous', 'pregnant' ), PdxGetWidgetScreenSize( PdxGuiWidget.Self ) )]"

		#mask = "gfx/portraits/portrait_mask_legend_chronicle.dds"
		mask = "gfx/portraits/portrait_mask_blank.dds"
		effectname = "NoHighlight"

		shaderfile = "gfx/FX/gui_painterly_portrait.shader"
		pop_out = yes # Painterly shader override for `pop_out` property, it now means "add outline"
		pop_out_v = 2.0 # Painterly shader override for `pop_out_v` property, it now means "outline width"
		grayscale = no
		#grayscale = yes
	}
	
	type pod_fleshcraft_perk_popup = widget {
		size = { 340 240 }
		#size = { 280 240 }
		
		### uncomment to visualize the size of the widget
		# background = {
		# 	using = Background_Frame
		# 	texture_density = 2
		# 	color = { 0 0 0 1 }
		# }
		
		text_single = {
			parentanchor = top|hcenter
			block "text_title" { raw_text = "Torso" }
			default_format = "#color:{0.0,0.0,0.0};glow_color:{0.2,0.0,0.0,0.4};FONT:TitleFont"
			fontsize = 20
			position = { 2 2 }
		}
		text_single = {
			parentanchor = top|hcenter
			block "text_title" { raw_text = "Torso" }
			default_format = "#color:{0.91,0.9,0.88,0.65};glow_color:{0.2,0.0,0.0,1.0};FONT:TitleFont"
			fontsize = 20
		}
		
		vbox = {
			layoutpolicy_vertical = expanding
			
			spacer = { size = { 0 32 } }
		
			button_standard_hover = {
				background = {
					using = pod_fleshcraft_perk_bg_solid
					color = { 0.15 0.04 0.02 1.0 }
				}
				background = {
					using = pod_fleshcraft_perk_bg_frames
				}
				
				datacontext = "[GetScriptedGui('POD_fleshcrafting_modify_flesh')]"
				
				enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot(GetPlayer.MakeScope).End )]"
				tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot(GetPlayer.MakeScope).End )]"
				button_ignore = none # allow right-clicking
				
				onrightclick = "[PdxGuiInterruptThenTriggerAllAnimations('fleshcraft_perk_clicksound','fleshcraft_perk_clicksound')]"
				
				block "button_flesh" {}
				
				text_multi = {
					block "text_flesh" {
						text = "[Select_CString( EqualTo_string( Scope.GetFlagKey, 'fc_unmodified_perk' ), Localize('POD_fleshcrafting_flesh_unassigned'), GetPerk(Scope.GetFlagKey).GetEffectDescription(GetPlayer.MakeScope.Var('fleshcraft_target').Char.Self) )]"
					}
					using = pod_fleshcraft_perk_text
					
					pod_fleshcraft_glow = {
						block "flesh_glow_visible" {}
						# blockoverride "background_properties" {
						# 	margin = { 10 8 }
						# 	tintcolor = { 1 0.3 0.4 1 }
						# }
					}
				}
			}
			
			spacer = { size = { 0 4 } }
			
			button_standard_hover = {
				background = {
					using = pod_fleshcraft_perk_bg_solid
					color = { 0.12 0.11 0.07 1.0 }
				}
				background = {
					using = pod_fleshcraft_perk_bg_frames
				}
				
				datacontext = "[GetScriptedGui('POD_fleshcrafting_modify_bone')]"
				
				enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot(GetPlayer.MakeScope).End )]"
				tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot(GetPlayer.MakeScope).End )]"
				button_ignore = none # allow right-clicking
				
				onrightclick = "[PdxGuiInterruptThenTriggerAllAnimations('fleshcraft_perk_clicksound','fleshcraft_perk_clicksound')]"
				
				block "button_bone" {}
				
				text_multi = {
					block "text_bone" {
						text = "[Select_CString( EqualTo_string( Scope.GetFlagKey, 'fc_unmodified_perk' ), Localize('POD_fleshcrafting_bone_unassigned'), GetPerk(Scope.GetFlagKey).GetEffectDescription(GetPlayer.MakeScope.Var('fleshcraft_target').Char.Self) )]"
					}
					using = pod_fleshcraft_perk_text
					
					pod_fleshcraft_glow = {
						block "bone_glow_visible" {}
						# blockoverride "background_properties" {
						# 	margin = { 10 8 }
						# 	tintcolor = { 0.6 0.7 0.6 1 }
						# }
					}
				}
			}
			
			spacer = { size = { 0 8 } }
			
			expand = {}
		}
	}
	type pod_fleshcraft_glow = widget {
		name = "selection_glow"
		parentanchor = center
		size = { 100% 100% }

		state = {
			trigger_on_create = yes

			name = max_glow
			next = min_glow
			duration = 1
			using = Animation_Curve_Default
			alpha = 0.5
		}

		state = {
			name = min_glow
			next = max_glow
			duration = 1.6
			using = Animation_Curve_Default
			alpha = 0.3
		}

		background = {
			texture = "gfx/interface/component_effects/innovation_glow.dds"
			spriteType = Corneredstretched
			spriteborder = { 30 30 }
			block "background_properties" {
				margin = { 10 8 }
				tintcolor = { 1 0.9 0.8 1 }
			}
		}
	}
}